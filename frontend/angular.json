{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"cli": {
		"packageManager": "bun",
		"schematicCollections": ["@schematics/angular"],
		"analytics": false
	},
	"newProjectRoot": "projects",
	"projects": {
		"gamenight-hub": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"changeDetection": "OnPush"
				}
			},
			"root": "",
			"sourceRoot": "src",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "@angular/build:application",
					"options": {
						"browser": "src/main.ts",
						"tsConfig": "tsconfig.app.json",
						"assets": [
							{
								"glob": "**/*",
								"input": "public"
							},
							{
								"glob": "**/*",
								"input": "src/app/features/home/assets",
								"output": "assets/home"
							},
							{
								"glob": "**/*",
								"input": "src/app/features/create-event/assets",
								"output": "assets/event-covers"
							}
						],
						"styles": ["src/styles.css", "node_modules/leaflet/dist/leaflet.css"],
						"allowedCommonJsDependencies": ["leaflet"]
					},
					"configurations": {
						"production": {
							"budgets": [
								{
									"type": "initial",
									"maximumWarning": "600kB",
									"maximumError": "1MB"
								},
								{
									"type": "anyComponentStyle",
									"maximumWarning": "4kB",
									"maximumError": "8kB"
								}
							],
							"outputHashing": "all",
							"serviceWorker": "ngsw-config.json",
							"fileReplacements": [
								{
									"replace": "src/environments/environment.ts",
									"with": "src/environments/environment.prod.ts"
								}
							]
						},
						"development": {
							"optimization": false,
							"extractLicenses": false,
							"sourceMap": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "@angular/build:dev-server",
					"configurations": {
						"production": {
							"buildTarget": "gamenight-hub:build:production"
						},
						"development": {
							"buildTarget": "gamenight-hub:build:development"
						}
					},
					"defaultConfiguration": "development"
				},
				"test": {
					"builder": "@angular/build:unit-test",
					"options": {
						"buildTarget": "gamenight-hub:build:development",
						"setupFiles": ["src/test-setup.ts"],
						"runnerConfig": true
					}
				}
			}
		}
	}
}
